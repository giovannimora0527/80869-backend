						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has citaId\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('citaId');",
							"});",
							"",
							"pm.test(\"Response has mensaje\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.mensaje).to.eql('Cita creada exitosamente');",
